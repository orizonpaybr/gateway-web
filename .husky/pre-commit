#!/bin/bash

# 🎯 Script de Pré-Commit - Coratri Gateway Web
# Este script valida o código antes de permitir o commit

set -e

echo "🚀 Executando validações pré-commit..."
echo ""

# Cores para output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Navegar para o diretório do projeto
cd "$(git rev-parse --show-toplevel)/gateway-web"

# 1. Type Check
echo "🔍 Verificando tipos TypeScript..."
if yarn type-check; then
    echo -e "${GREEN}✅ Type check passou!${NC}"
    echo ""
else
    echo -e "${RED}❌ Erros de tipo encontrados!${NC}"
    echo -e "${YELLOW}Por favor, corrija os erros de TypeScript antes de commitar.${NC}"
    exit 1
fi

# 2. Lint
echo "🧹 Executando lint..."
if yarn lint; then
    echo -e "${GREEN}✅ Lint passou!${NC}"
    echo ""
else
    echo -e "${RED}❌ Erros de lint encontrados!${NC}"
    echo -e "${YELLOW}Tentando corrigir automaticamente...${NC}"
    
    if yarn lint:fix; then
        echo -e "${GREEN}✅ Erros corrigidos automaticamente!${NC}"
        echo -e "${YELLOW}⚠️  Por favor, adicione os arquivos corrigidos e commite novamente.${NC}"
        echo ""
        git status --short
        exit 1
    else
        echo -e "${RED}❌ Não foi possível corrigir automaticamente.${NC}"
        echo -e "${YELLOW}Por favor, corrija os erros de lint manualmente.${NC}"
        exit 1
    fi
fi

# 3. Build (comentado por padrão pois pode ser demorado)
# Descomente as linhas abaixo se quiser validar o build antes de cada commit
# echo "🏗️  Testando build..."
# if yarn build; then
#     echo -e "${GREEN}✅ Build passou!${NC}"
#     echo ""
# else
#     echo -e "${RED}❌ Build falhou!${NC}"
#     echo -e "${YELLOW}Por favor, corrija os erros de build antes de commitar.${NC}"
#     exit 1
# fi

echo -e "${GREEN}🎉 Todas as validações passaram! Prosseguindo com o commit...${NC}"
echo ""

exit 0
